---
interface Props {
  lang: string;
  file?: string;
}
const { lang, file } = Astro.props;
---

<div class="code">
  <div class="code-head">
    <span class="lang">{lang}</span>
    {file && <span class="file">{file}</span>}
    <button class="copy" type="button" aria-label="Copy code to clipboard">
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="6" height="6" rx="1" />
        <path d="M5 3V1.5h5v5H8.5" />
      </svg>
      <span>Copy</span>
    </button>
  </div>
  <div class="code-body">
    <slot />
  </div>
</div>

<script>
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element | null)?.closest<HTMLButtonElement>('.code-head .copy');
    if (!btn) return;
    const code = btn.closest('.code')?.querySelector('code');
    if (!code) return;
    try {
      await navigator.clipboard.writeText((code as HTMLElement).innerText);
    } catch {
      return;
    }
    const label = btn.querySelector('span');
    if (!label) return;
    const old = label.textContent;
    label.textContent = 'Copied';
    window.setTimeout(() => {
      label.textContent = old;
    }, 1100);
  });
</script>
